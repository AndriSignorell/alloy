Package: alloy
Type: Package
Title: Unified Modeling Framework for Regression and Classification
Version: 0.0.0.901
Date: 2026-05-21
Authors@R: c(
  person("Andri", "Signorell", email = "andri@signorell.net", role = c("aut", "cre"))
